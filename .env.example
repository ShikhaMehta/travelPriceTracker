# ─── Amadeus API (flights + hotels) ───────────────────────────────────────────
# Sign up free at: https://developers.amadeus.com
AMADEUS_API_KEY=your_amadeus_api_key_here
AMADEUS_API_SECRET=your_amadeus_api_secret_here

# ─── RapidAPI (Airbnb) ────────────────────────────────────────────────────────
# Sign up free at: https://rapidapi.com
# Subscribe to "Airbnb13" API (free tier): https://rapidapi.com/MakeMoney10101/api/airbnb13
RAPIDAPI_KEY=your_rapidapi_key_here

# ─── Gmail (alert emails) ─────────────────────────────────────────────────────
# Use a Gmail App Password (NOT your real password)
# How to get one: https://myaccount.google.com/apppasswords
GMAIL_SENDER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here
GMAIL_RECIPIENT=recipient@example.com
